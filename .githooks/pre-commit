#!/usr/bin/env bash
set -euo pipefail

blocked=0

if git diff --cached --name-only --diff-filter=ACMR | grep -E '(^|/)\.env($|[.])' | grep -Ev '(\.example|\.sample)$' >/dev/null; then
  echo "pre-commit: refusing to commit .env-like files unless they end in .example or .sample" >&2
  git diff --cached --name-only --diff-filter=ACMR | grep -E '(^|/)\.env($|[.])' | grep -Ev '(\.example|\.sample)$' >&2
  blocked=1
fi

patterns=(
  'sk-proj-[A-Za-z0-9_-]{20,}'
  'sk-[A-Za-z0-9]{32,}'
  'sk-ant-api[0-9]{2}-[A-Za-z0-9_-]{20,}'
  'gh[pousr]_[A-Za-z0-9_]{30,}'
  'github_pat_[A-Za-z0-9_]{40,}'
  'AKIA[0-9A-Z]{16}'
  'AIza[0-9A-Za-z_-]{35}'
  '-----BEGIN (RSA |EC |OPENSSH |DSA )?PRIVATE KEY-----'
)

while IFS= read -r file; do
  [[ "$file" == ".githooks/pre-commit" ]] && continue
  [[ -f "$file" ]] || continue
  if ! git grep -I -q --cached -e '' -- "$file" 2>/dev/null; then
    continue
  fi
  staged_content="$(git show ":$file" 2>/dev/null || true)"
  for pattern in "${patterns[@]}"; do
    if printf '%s\n' "$staged_content" | grep -E -e "$pattern" >/dev/null; then
      echo "pre-commit: possible secret in $file matching pattern: $pattern" >&2
      blocked=1
    fi
  done
done < <(git diff --cached --name-only --diff-filter=ACMR)

if [[ "$blocked" -ne 0 ]]; then
  echo "pre-commit: commit blocked. Remove the sensitive value or use a placeholder/example file." >&2
  exit 1
fi
